rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Seed / reference data: read-only for all authenticated users
    match /exercises/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && resource == null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.isBuiltIn == false;
    }

    // User documents: own profile only
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if false;   // created by onUserCreate Cloud Function
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['id', 'email', 'meta']);
      allow delete: if false;
    }

    // Programs: own data only
    match /programs/{programId} {
      allow read, write: if isSignedIn()
        && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
    }

    // Sessions: own data only
    match /sessions/{sessionId} {
      allow read, write: if isSignedIn()
        && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
    }

    // Assessments: own data only
    match /assessments/{assessmentId} {
      allow read, write: if isSignedIn()
        && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
    }

    // Sleep logs: own data only
    match /sleepLogs/{sleepLogId} {
      allow read, write: if isSignedIn()
        && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
    }

    // Progression rules: own data only
    match /progressionRules/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Goals: own data only
    match /goals/{goalId} {
      allow read, write: if isSignedIn()
        && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
    }

    // Compensations: own data only
    match /compensations/{compensationId} {
      allow read, write: if isSignedIn()
        && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
    }
  }
}
